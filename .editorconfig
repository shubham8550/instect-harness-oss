root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space

[*.rs]
indent_size = 4

[*.{py,pyi}]
indent_size = 4

[*.{js,jsx,ts,tsx,mjs,cjs,json,yml,yaml,toml,md}]
indent_size = 2

[Makefile]
indent_style = tab

[justfile]
indent_size = 2
